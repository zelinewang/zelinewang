  <g>
    <text x="64" y="498" fill="#a13a28" font-family="ui-monospace, monospace" font-size="11" letter-spacing="0.18em">AGENT / MEMORY</text>
    <text x="240" y="500" fill="#1f1c14" font-family="Charter, Cambria, Georgia, serif" font-size="22" font-weight="600">claudemem</text>
    <text x="240" y="528" fill="#1f1c14" font-family="Charter, Cambria, Georgia, serif" font-size="14">Persistent memory for coding agents, kept as portable Markdown records</text>
    <text x="240" y="546" fill="#1f1c14" font-family="Charter, Cambria, Georgia, serif" font-size="14">with searchable indexing across sessions.</text>
    <text x="900" y="528" fill="#7d7560" font-family="Charter, Cambria, Georgia, serif" font-style="italic" font-size="13">memory should survive</text>
    <text x="900" y="544" fill="#7d7560" font-family="Charter, Cambria, Georgia, serif" font-style="italic" font-size="13">the conversation.</text>
    <line x1="64" y1="570" x2="1136" y2="570" stroke="#1f1c14" stroke-opacity="0.10" stroke-width="0.4"/>
  </g>

