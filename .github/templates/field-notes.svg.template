  <g transform="translate(64, 2180)">
    <text x="0" y="0" fill="#a13a28" font-family="ui-monospace, monospace" font-size="11" letter-spacing="0.18em">I.</text>
    <text x="40" y="2" fill="#1f1c14" font-family="Charter, Cambria, Georgia, serif" font-size="20" font-weight="600">cut the noise.</text>
    <text x="40" y="26" fill="#7d7560" font-family="Charter, Cambria, Georgia, serif" font-style="italic" font-size="14">consolidate what overlaps; simplify what is tangled.</text>

    <text x="0" y="74" fill="#a13a28" font-family="ui-monospace, monospace" font-size="11" letter-spacing="0.18em">II.</text>
    <text x="40" y="76" fill="#1f1c14" font-family="Charter, Cambria, Georgia, serif" font-size="20" font-weight="600">sharpen the tools first.</text>
    <text x="40" y="100" fill="#7d7560" font-family="Charter, Cambria, Georgia, serif" font-style="italic" font-size="14">leverage beats brute force.</text>

    <text x="0" y="148" fill="#a13a28" font-family="ui-monospace, monospace" font-size="11" letter-spacing="0.18em">III.</text>
    <text x="40" y="150" fill="#1f1c14" font-family="Charter, Cambria, Georgia, serif" font-size="20" font-weight="600">prove before you argue.</text>
    <text x="40" y="174" fill="#7d7560" font-family="Charter, Cambria, Georgia, serif" font-style="italic" font-size="14">replace debate with experiment.</text>

    <text x="0" y="222" fill="#a13a28" font-family="ui-monospace, monospace" font-size="11" letter-spacing="0.18em">IV.</text>
    <text x="40" y="224" fill="#1f1c14" font-family="Charter, Cambria, Georgia, serif" font-size="20" font-weight="600">let reality disprove.</text>
    <text x="40" y="248" fill="#7d7560" font-family="Charter, Cambria, Georgia, serif" font-style="italic" font-size="14">never defend a position; update it.</text>
